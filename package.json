{
  "name": "@bkper/bkper-api-types",
  "version": "5.43.0",
  "description": "Typescript definitions for Bkper REST API",
  "homepage": "https://api.bkper.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bkper/bkper-api-types.git"
  },
  "bugs": {
