  },
  "license": "MIT",
  "scripts": {
    "build": "dtsgen -o index.d.ts --url https://bkper.com/docs/api/rest/openapi.json",
    "release:patch": "npm version patch -m \"chore(release): v%s\"",
    "release:minor": "npm version minor -m \"chore(release): v%s\"",
    "release:major": "npm version major -m \"chore(release): v%s\"",
    "preversion": "bun run build",
    "version": "git add index.d.ts"
  },
  "devDependencies": {
    "@dtsgenerator/replace-namespace": "^1.3.2",
    "dtsgenerator": "^3.3.0"
  },
